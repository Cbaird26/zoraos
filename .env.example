# ZoraOS Configuration
# Copy to .env and fill in your values

# Core Settings
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=DEBUG
DATA_DIR=./data

# Database
DATABASE_URL=postgresql+asyncpg://zoraos:zoraos@localhost:5432/zoraos
DATABASE_URL_SYNC=postgresql://zoraos:zoraos@localhost:5432/zoraos
REDIS_URL=redis://localhost:6379/0

# Vector Store
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma

# Model Providers
# OpenAI
PROVIDERS__OPENAI__API_KEY=
PROVIDERS__OPENAI__MODEL=gpt-4o

# Anthropic
PROVIDERS__ANTHROPIC__API_KEY=
PROVIDERS__ANTHROPIC__MODEL=claude-sonnet-4-20250514

# DeepSeek
PROVIDERS__DEEPSEEK__API_KEY=
PROVIDERS__DEEPSEEK__MODEL=deepseek-chat
PROVIDERS__DEEPSEEK__API_BASE=https://api.deepseek.com

# Kimi (Moonshot)
PROVIDERS__KIMI__API_KEY=
PROVIDERS__KIMI__MODEL=kimi-k2
PROVIDERS__KIMI__API_BASE=https://api.moonshot.cn

# Qwen
PROVIDERS__QWEN__API_KEY=
PROVIDERS__QWEN__MODEL=qwen-max
PROVIDERS__QWEN__API_BASE=https://dashscope.aliyuncs.com

# OpenRouter
PROVIDERS__OPENROUTER__API_KEY=
PROVIDERS__OPENROUTER__MODEL=openrouter/tencent/hy3
PROVIDERS__OPENROUTER__API_BASE=https://openrouter.ai/api/v1

# Ollama (local)
PROVIDERS__OLLAMA__API_BASE=http://localhost:11434
PROVIDERS__OLLAMA__MODEL=zora:core

# Grok (xAI)
PROVIDERS__GROK__API_KEY=
PROVIDERS__GROK__MODEL=grok-3

# Gateway
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=8000
GATEWAY_SECRET_KEY=change-me-to-a-random-string
# Protected routes allow placeholder-key access only from loopback. After replacing
# this value, clients must send: X-ZoraOS-Key: <your configured value>
# The daemon reads ZORA_DAEMON_KEY only when a real gateway key is configured.
# ZORA_DAEMON_KEY=

# Default Provider
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=openrouter/tencent/hy3

# Memory
MEMORY__EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MEMORY__TOP_K=10
MEMORY__COLLECTIONS=research,books,physics,ai,projects,software,therapy,gaming,journal,ideas,meetings,papers,videos

# Scheduler
SCHEDULER_ENABLED=true

# Cluster
CLUSTER__NODE_NAME=m5-orchestrator
CLUSTER__NODE_ROLE=orchestrator
CLUSTER__NODE_CAPABILITIES=orchestrator,models,tools
