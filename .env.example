# ZoraOS Configuration
# Copy to .env and fill in your values

# Core Settings
ZORAOS_ENV=development
ZORAOS_DEBUG=true
ZORAOS_LOG_LEVEL=DEBUG
ZORAOS_DATA_DIR=./data

# Database
DATABASE_URL=postgresql+asyncpg://zoraos:zoraos@localhost:5432/zoraos
DATABASE_URL_SYNC=postgresql://zoraos:zoraos@localhost:5432/zoraos
REDIS_URL=redis://localhost:6379/0

# Vector Store
VECTOR_STORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chroma

# Model Providers
# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_BASE=https://api.deepseek.com

# Kimi (Moonshot)
KIMI_API_KEY=
KIMI_MODEL=kimi-k2
KIMI_API_BASE=https://api.moonshot.cn

# Qwen
QWEN_API_KEY=
QWEN_MODEL=qwen-max
QWEN_API_BASE=https://dashscope.aliyuncs.com

# Ollama (local)
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Grok (xAI)
XAI_API_KEY=
XAI_MODEL=grok-3

# Gateway
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_SECRET_KEY=change-me-to-a-random-string

# Default Provider
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3.2

# Memory
MEMORY_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MEMORY_TOP_K=10
MEMORY_COLLECTIONS=research,books,physics,ai,projects,software,therapy,gaming,journal,ideas,meetings,papers,videos

# Scheduler
SCHEDULER_ENABLED=true

# Cluster
CLUSTER_NODE_NAME=m5-orchestrator
CLUSTER_NODE_ROLE=orchestrator
CLUSTER_NODE_CAPABILITIES=orchestrator,models,tools
